NDN_SVS_SCORE_RECENT_WEIGHT=0.55
NDN_SVS_SCORE_FAIR_WEIGHT=0.25
NDN_SVS_SCORE_PREFERRED_BOOST=0.85
NDN_SVS_FIXED_INTERVAL_MS=30000

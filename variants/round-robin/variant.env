# Same entry budget as other partial variants, but using round-robin selection only
NDN_SVS_TIMER_MODE=network-aware
NDN_SVS_VECTOR_STRATEGY=round-robin
NDN_SVS_STATE_VECTOR_RATIO=0.30
NDN_SVS_MAX_STATE_VECTOR_ENTRIES=32
NDN_SVS_RECENT_ENTRIES=0
NDN_SVS_FIXED_INTERVAL_MS=30000
NDN_SVS_TIMER_JITTER=0.10
NDN_SVS_COORDINATED_SYNC=1
NDN_SVS_LOG_METRICS=1
